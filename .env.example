# Database Configuration
DATABASE_URL=postgresql://[user].[project_ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.[project_ref].supabase.co:5432/postgres

# Supabase API Configuration (If using client SDKs)
SUPABASE_URL=https://[project_ref].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Redis & Queues Configuration
REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=5

# JWT Configuration
JWT_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# Security & Encryption
CERTIFICATE_ENCRYPTION_KEY=32_character_hex_key_here
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# DGII Integration
DGII_ENVIRONMENT=test
DGII_API_URL_TEST=https://ecf.dgii.gov.do/testapi
DGII_API_URL_PRODUCTION=https://ecf.dgii.gov.do/api

# Mail Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Local Storage
STORAGE_PATH=./storage

# Document Printing Module
PDF_TEMP_DIR=./storage/temp-docs
URL_SIGNATURE_SECRET=super_secret_hmac_key_for_printing_2026_!@#
